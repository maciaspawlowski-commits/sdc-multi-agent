# ── Ollama (local — no API key needed) ────────────────────────────────────
# Install: https://ollama.com  →  brew install ollama
# Pull a model: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434

# Model to run — any model you've pulled with `ollama pull <name>`
# Good options: llama3.2 (fast), mistral, gemma3, phi4-mini
LLM_MODEL=llama3.2

# ── Dash0 ──────────────────────────────────────────────────────────────────
# Get your token at https://app.dash0.com → Settings → Auth Tokens
DASH0_AUTH_TOKEN=

# Optional: scope data to a specific Dash0 dataset
# DASH0_DATASET=default

# ── OTLP endpoint ──────────────────────────────────────────────────────────
# US:  https://ingress.us1.dash0.com
# EU:  https://ingress.eu1.dash0.com
# Leave blank to print traces to the console (great for local dev)
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingress.us1.dash0.com

# ── App config ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=llm-demo
ENVIRONMENT=demo
